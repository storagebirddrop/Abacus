# Abacus configuration
# Copy to .env and adjust as needed

# HTTP port
PORT=8080

# SQLite database path
DB_PATH=./abacus.db

# Environment: development | production
ENV=production

# Application version (set by build)
VERSION=0.1.0

# Directory containing the compiled frontend (web/dist)
FRONTEND_DIR=./web/dist

# --- API security ---
# Optional bearer token. When set, every /api/v1 request (except health/version)
# must send `Authorization: Bearer <token>`. Off by default — intended for
# deployments exposed beyond localhost (e.g. behind a reverse proxy). NOTE: the
# bundled web UI does not yet attach this token, so enabling it is for
# API/proxy-fronted use. Leave empty for the default offline/localhost setup.
# API_TOKEN=

# Per-IP request cap for /api/v1, requests per minute. Set to 0 to disable.
RATE_LIMIT_RPM=600

# Blockchain sync (Esplora / Electrum backend, URLs, TLS, rate limit) is NOT
# configured here. It is disabled by default and configured at runtime in the
# in-app Settings page, persisted in SQLite — no restart needed. See the
# Settings tab in the UI.
#
# Privacy: enabling sync queries the configured server for your wallet's
# addresses, disclosing them to that third party. For maximum privacy, point it
# at an Esplora/Electrum instance you host yourself. Abacus never stores or
# transmits keys or signing material.
